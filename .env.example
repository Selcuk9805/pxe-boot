# ============================================================
# PXE Boot Sunucusu - Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve düzenleyin:
#   cp .env.example .env
# ============================================================

# PXE sunucusunun statik IP adresi
PXE_SERVER_IP=10.30.1.20

# Ağ subnet'i (proxy DHCP için, sadece ilk 3 oktet + .0)
NETWORK_SUBNET=10.30.1.0

# dnsmasq'ın dinleyeceği ağ arayüzü
# Boş bırakırsanız tüm arayüzleri dinler.
# Örnek: LISTEN_INTERFACE=eth0  veya  LISTEN_INTERFACE=enp3s0
LISTEN_INTERFACE=

# Zaman dilimi
TZ=Europe/Istanbul
